# alpha-compass — environment variables (DEV ONLY)
# 本ファイルは開発用のサンプル。実運用ではトークンは OS キーチェーンに格納し、
# .env はコミットしないこと（.gitignore 済み）。Rust(Tauri Core) が資格情報を管理し、
# サイドカーへは起動時/必要時にのみ受け渡す。

# --- J-Quants (v1: FREE plan) ---
# 無料プランは配信遅延あり。リフレッシュトークン方式 or メール+パスワードでの発行。
JQUANTS_REFRESH_TOKEN=
# 代替（リフレッシュトークン未取得時に発行する場合）
JQUANTS_MAILADDRESS=
JQUANTS_PASSWORD=

# --- FRED (free API key) ---
FRED_API_KEY=

# --- Anthropic (AI cascade Tier3) ---
ANTHROPIC_API_KEY=
# Tier3 の暴発防止（1日あたりの上限の目安）
AI_TIER3_DAILY_BUDGET_USD=2.0

# --- Local LLM (Tier2 / Qwen MoE on RTX 5090) ---
LOCAL_LLM_ENDPOINT=http://127.0.0.1:8080
LOCAL_LLM_MODEL=qwen-moe

# --- Sidecar ---
# 通常は Rust が起動時に動的ポート＋セッショントークンを割り当てる。
# 手動起動・デバッグ時のみ使用。
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=
SIDECAR_SESSION_TOKEN=

# --- News / Calendar (任意・利用するプロバイダに応じて) ---
NEWS_API_KEY=
CALENDAR_API_KEY=
